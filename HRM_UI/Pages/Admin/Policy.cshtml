@page
@model HRM_UI.Pages.Admin.PolicyModel
@{
    ViewData["Title"] = "Admin Dashboard - Policy";
}

<style>
    :root {
        /* Font */
        --font-family-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
        /* Colors */
        --color-bg-default: #f6f8fa;
        --color-bg-primary: #ffffff;
        --color-text-primary: #1f2328;
        --color-text-secondary: #57606a;
        --color-border-default: #d0d7de;
        --color-border-muted: #d8dee4;
        --color-accent-primary: #0969da;
        --color-accent-fg: #0969da;
        --color-accent-subtle: #ddf4ff;
        --color-sidebar-item-hover-bg: #f3f4f6;
        /* Spacing & Sizing */
        --space-1: 4px;
        --space-2: 8px;
        --space-3: 12px;
        --space-4: 16px;
        --space-5: 24px;
        --space-6: 32px;
        --space-7: 48px;
        --sidebar-width: 240px;
        /* Radius & Shadow */
        --radius-sm: 4px;
        --radius-md: 6px;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        /* Transition */
        --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Apply base styles */
    /* Assuming a parent selector or body style sets the background */
    /* For standalone page, you might need to style body or a container */

    .dashboard-container {
        font-family: var(--font-family-sans);
        max-width: 1280px;
        margin: 0 auto;
        padding: var(--space-6) var(--space-5);
    }

    .dashboard-layout {
        display: grid;
        grid-template-columns: 1fr; /* Default for small screens */
        gap: var(--space-6);
    }

    @@media (min-width: 992px) {
        .dashboard-layout {
            grid-template-columns: var(--sidebar-width) 1fr; /* Sidebar on the left */
        }
    }

    /* --- Sidebar --- */
    .sidebar-title {
        font-size: 0.75rem; /* 12px */
        font-weight: 600;
        color: var(--color-text-primary);
        padding: 0 var(--space-3);
        margin-bottom: var(--space-2);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar-nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-nav-item {
        margin-bottom: var(--space-1);
    }

    .sidebar-nav-link {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-3);
        color: var(--color-text-primary);
        text-decoration: none;
        border-radius: var(--radius-md);
        font-size: 0.875rem; /* 14px */
        font-weight: 500;
        transition: background-color var(--transition-fast), color var(--transition-fast);
    }

        .sidebar-nav-link svg {
            color: var(--color-text-secondary);
        }

        .sidebar-nav-link:hover {
            background: var(--color-sidebar-item-hover-bg);
        }

        .sidebar-nav-link.active {
            background: var(--color-accent-subtle);
            color: var(--color-accent-fg);
            font-weight: 600;
        }

            .sidebar-nav-link.active svg {
                color: var(--color-accent-fg);
            }

    /* --- Main Content --- */
    .dashboard-header {
        margin-bottom: var(--space-6);
    }

    .dashboard-title {
        font-size: 1.875rem; /* 30px */
        font-weight: 600;
        color: var(--color-text-primary);
        margin: 0 0 var(--space-1) 0;
    }

    .dashboard-subtitle {
        font-size: 1rem; /* 16px */
        color: var(--color-text-secondary);
        margin: 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: var(--space-5);
        margin-bottom: var(--space-5);
    }

    .stat-card, .welcome-card {
        background: var(--color-bg-primary);
        border: 1px solid var(--color-border-default);
        border-radius: var(--radius-md);
        padding: var(--space-5);
        transition: all var(--transition-fast);
        box-shadow: var(--shadow-sm);
    }

        .stat-card:hover {
            box-shadow: var(--shadow-md);
            border-color: var(--color-border-muted);
        }

    .stat-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        margin-bottom: var(--space-2);
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 600;
        line-height: 1;
        color: var(--color-text-primary);
        margin: 0;
    }

    .stat-sub-value {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        margin-top: var(--space-2);
    }

    .welcome-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: var(--space-7) var(--space-5);
    }

    .welcome-icon {
        width: 56px;
        height: 56px;
        background: var(--color-accent-subtle);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-4);
        font-size: 1.75rem;
    }

    .welcome-message {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--color-text-primary);
        margin-bottom: var(--space-2);
    }

    /* --- Utility & Loading --- */
    .alert {
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-md);
        margin-bottom: var(--space-5);
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .alert-danger {
        background-color: #ffebe9;
        border: 1px solid #ffc1ba;
        color: #c92c19;
    }

    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 3px solid var(--color-border-muted);
        border-top-color: var(--color-accent-primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: var(--space-4);
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Admin Dashboard</h1>
        <p class="dashboard-subtitle">Manage your organization's resources and settings.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink: 0;">
                <path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 100 13a6.5 6.5 0 000-13zM0 8a8 8 0 1116 0A8 8 0 010 8zm6.5-.25A.75.75 0 017.25 7h1.5a.75.75 0 010 1.5h-1.5A.75.75 0 016.5 7.75zM8 12a1 1 0 100-2 1 1 0 000 2z"></path>
            </svg>
            <span>@Model.ErrorMessage</span>
        </div>
    }
    else 
    {
        <div class="dashboard-layout">
            <aside class="dashboard-sidebar">
                <h3 class="sidebar-title">Management</h3>
                <ul class="sidebar-nav-list">
                    <li class="sidebar-nav-item">
                        <a asp-page="/Admin/User" asp-page-handler="Index" class="sidebar-nav-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332C4.154 12.014 4.001 12.754 4 13h10z" /></svg>
                            User Management
                        </a>
                    </li>
                    <li class="sidebar-nav-item">
                        <a asp-page="/Admin/Department" asp-page-handler="Index" class="sidebar-nav-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 1a.5.5 0 0 0 0 1h1.11L2.897 6.24a.5.5 0 0 0 .491.565l2.553.159a.5.5 0 0 0 .456-.273L8.4 3.84a.5.5 0 0 0-.273-.658L5.35 1.597a.5.5 0 0 0-.523-.012L.5 3.847V1.5A.5.5 0 0 0 .5 1zM8 3.5a.5.5 0 0 1 .582.423l.907 3.631a.5.5 0 0 1-.318.582l-3.415.854a.5.5 0 0 1-.582-.423L4.26 4.934a.5.5 0 0 1 .318-.582l3.415-.853A.5.5 0 0 1 8 3.5zM14 3.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zM14.5 9a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0zM5.5 14a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0zM11 11.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm-4.328-.555a.5.5 0 0 1 .256-.472l2.427-1.456a.5.5 0 0 1 .744.544l-1.456 2.427a.5.5 0 0 1-.744-.544l-.227-.379-.379-.227a.5.5 0 0 1-.299-.744z" /></svg>
                            Department Management
                        </a>
                    </li>
                    <li class="sidebar-nav-item">
                        <a asp-page="/Admin/Policy" class="sidebar-nav-link active">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" /><path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z" /></svg>
                            Policies
                        </a>
                    </li>
                    <li class="sidebar-nav-item">
                        <a asp-page="/Admin/Setting" asp-page-handler="Index" class="sidebar-nav-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311a1.464 1.464 0 0 1-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413-1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z" /></svg>
                            System Settings
                        </a>
                    </li>
                </ul>
            </aside>

            Policy settings
        </div>
    }
</div>
