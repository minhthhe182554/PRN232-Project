<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRM System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .top-navbar {
            background: var(--color-bg-primary);
            border-bottom: 1px solid var(--color-border-default);
            position: sticky;
            top: 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }
        
        .navbar-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 var(--space-5);
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 60px;
        }
        
        .navbar-brand {
            font-weight: 600;
            font-size: 1rem;
            color: var(--color-text-primary);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }
        
        .navbar-brand:hover {
            color: var(--color-accent-primary);
        }
        
        .navbar-brand-icon {
            width: 24px;
            height: 24px;
            background: var(--color-accent-primary);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.875rem;
            font-weight: 700;
        }
        
        .navbar-end {
            display: flex;
            align-items: center;
            gap: var(--space-4);
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: var(--space-3);
            font-size: 0.875rem;
        }
        
        .user-name {
            color: var(--color-text-primary);
            font-weight: 500;
        }
        
        .user-role-badge {
            background: var(--color-bg-secondary);
            color: var(--color-text-secondary);
            padding: 0.25rem 0.5rem;
            border-radius: var(--radius-sm);
            font-size: 0.75rem;
            font-weight: 500;
            border: 1px solid var(--color-border-default);
        }
        
        button.btn-logout {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif;
            background: #cb2431; /* Màu đỏ */
            color: #ffffff; /* Màu chữ trắng */
            border: 1px solid #cb2431; /* Viền đỏ */
            padding: 5px 16px;
            border-radius: 6px; /* Bo góc */
            font-size: 14px;
            font-weight: 500;
            line-height: 20px;
            white-space: nowrap;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.3, 0, 0.5, 1);
            box-shadow: 0 1px 0 rgba(27, 31, 36, 0.04);
        }

        button.btn-logout:hover {
            background: #cb2431; /* Giữ màu đỏ khi di chuột */
            border-color: rgba(27, 31, 36, 0.15);
            transition-duration: 0.1s;
            opacity: 0.9; /* Giảm độ mờ khi di chuột */
        }

        button.btn-logout:active {
            background: #cb2431; /* Giữ màu đỏ khi nhấn */
            box-shadow: inset 0 1px 0 rgba(27, 31, 36, 0.04);
            opacity: 0.8; /* Giảm độ mờ khi nhấn */
        }

        /* Main Content */
        main {
            min-height: calc(100vh - 60px);
            padding: var(--space-6) 0;
        }
        
        /* Mobile Responsive */
        @@media (max-width: 768px) {
            .navbar-container {
                padding: 0 var(--space-4);
            }
            
            .user-name {
                display: none;
            }
        }
    </style>
</head>
<body>
    <nav class="top-navbar">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">
                <div class="navbar-brand-icon">HRM</div>
                <span>HRM System</span>
            </a>
            
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="navbar-end">
                    <div class="user-info">
                        <span class="user-name">@User.Identity.Name</span>
                        <span class="user-role-badge">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                    <form method="post" asp-page="/Logout" style="margin: 0;">
                        <button type="submit" class="btn-logout">Sign out</button>
                    </form>
                </div>
            }
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>