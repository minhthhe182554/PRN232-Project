@page
@model HRM_UI.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in - HRM System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: var(--color-bg-secondary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--space-5);
        }
        
        .login-container {
            background: var(--color-bg-primary);
            border: 1px solid var(--color-border-default);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            padding: 3rem;
            width: 100%;
            max-width: 400px;
        }
        
        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .login-icon {
            width: 48px;
            height: 48px;
            background: var(--color-accent-primary);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0 auto 1rem;
        }
        
        .login-header h1 {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--color-text-primary);
            margin-bottom: 0.5rem;
        }
        
        .login-header p {
            color: var(--color-text-secondary);
            font-size: 0.875rem;
            margin: 0;
        }
        
        .form-group {
            margin-bottom: 1rem;
        }
        
        .form-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--color-text-primary);
            margin-bottom: 0.5rem;
        }
        
        .form-control {
            width: 100%;
            padding: 0.625rem 0.75rem;
            font-size: 0.875rem;
            line-height: 1.5;
            color: var(--color-text-primary);
            background: var(--color-bg-primary);
            border: 1px solid var(--color-border-default);
            border-radius: var(--radius-sm);
            transition: all var(--transition-fast);
        }
        
        .form-control:focus {
            outline: none;
            border-color: var(--color-accent-primary);
            box-shadow: 0 0 0 3px var(--color-accent-subtle);
        }
        
        .form-control::placeholder {
            color: var(--color-text-placeholder);
        }
        
        .btn-login {
            width: 100%;
            padding: 0.625rem 1rem;
            margin-top: 1.5rem;
            background: var(--color-accent-primary);
            color: white;
            border: 1px solid var(--color-accent-primary);
            border-radius: var(--radius-sm);
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: all var(--transition-fast);
        }
        
        .btn-login:hover {
            background: var(--color-accent-hover);
            border-color: var(--color-accent-hover);
        }
        
        .btn-login:active {
            transform: translateY(1px);
        }
        
        .alert {
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
            border-radius: var(--radius-sm);
            font-size: 0.875rem;
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
        }
        
        .alert-danger {
            background: var(--color-danger-bg);
            border: 1px solid rgba(207, 34, 46, 0.2);
            color: var(--color-danger);
        }
        
        .alert-icon {
            flex-shrink: 0;
            margin-top: 1px;
        }
        
        @@media (max-width: 480px) {
            .login-container {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <div class="login-icon">HR</div>
            <h1>Sign in to HRM</h1>
            <p>Enter your credentials to access your account</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <svg class="alert-icon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM7 4v5h2V4H7zm0 6v2h2v-2H7z"/>
                </svg>
                <span>@Model.ErrorMessage</span>
            </div>
        }

        <form method="post">
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email address</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="name@example.com" required autofocus />
            </div>
            
            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" required />
            </div>
            
            <button type="submit" class="btn-login">Sign in</button>
        </form>
    </div>
</body>
</html>
